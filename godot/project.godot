; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Freedroid"
run/main_scene="uid://dp3wxbkx8r50c"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GlobalState="*res://autoloads/global_state.gd"
BulletManager="*res://autoloads/bullet_manager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=2940
window/size/window_height_override=1912
window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/data_converter/plugin.cfg", "res://addons/gut/plugin.cfg")

[global_group]

player=""

